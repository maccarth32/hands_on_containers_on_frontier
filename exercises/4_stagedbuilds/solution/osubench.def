Bootstrap: docker
From: savannah.ornl.gov/olcf-container-images/cpe:24.11_gnu_ubuntu
Stage: devel

%post

apt-get install -y curl
echo "Compiling the MPI application..."
curl -o osubenchmarks-7.5.2.tar.gz  https://mvapich.cse.ohio-state.edu/download/mvapich/osu-micro-benchmarks-7.5.2.tar.gz  && tar -xzf osubenchmarks-7.5.2.tar.gz --no-same-owner
cd osu-micro-benchmarks-7.5.2 && ./configure CC=mpicc CXX=mpicc --enable-rocm --with-rocm=/opt/rocm && make  && rm ../osubenchmarks-7.5.2.tar.gz


Bootstrap: docker
From: ubuntu:24.04
Stage: final

%files from devel
    /lib/x86_64-linux-gnu/libc.so.6 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libdrm_amdgpu.so.1 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libdrm.so.2 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libelf.so.1 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libm.so.6 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libnuma.so.1 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libpciaccess.so.0 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libquadmath.so.0.0.0 /lib/x86_64-linux-gnu/libquadmath.so.0
    /lib/x86_64-linux-gnu/libtinfo.so.6 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libz.so.1 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libxml2.so.2 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libicuuc.so.74 /lib/x86_64-linux-gnu
    /lib/x86_64-linux-gnu/libicudata.so.74 /lib/x86_64-linux-gnu

    /opt/gcc/13.2.0/lib64/libatomic.so.1 /lib/x86_64-linux-gnu
    /opt/gcc/13.2.0/lib64/libgcc_s.so.1 /lib/x86_64-linux-gnu
    /opt/gcc/13.2.0/lib64/libstdc++.so.6  /lib/x86_64-linux-gnu

    /opt/mpich/3.4.3/lib/libmpicxx.so.12 /lib/x86_64-linux-gnu
    /opt/mpich/3.4.3/lib/libmpi.so.12 /lib/x86_64-linux-gnu

    /opt/rocm-6.2.4/lib/libamd_comgr.so.2 /lib/x86_64-linux-gnu
    /opt/rocm-6.2.4/lib/libamdhip64.so.6 /lib/x86_64-linux-gnu 
    /opt/rocm-6.2.4/lib/libhsa-runtime64.so.1 /lib/x86_64-linux-gnu
    /opt/rocm-6.2.4/lib/librocprofiler-register.so.0 /lib/x86_64-linux-gnu 

    /osu-micro-benchmarks-7.5.2/c/mpi/collective/blocking/osu_allgather /opt

    
